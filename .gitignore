# ==========================================
# General OS / IDE
# ==========================================
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ==========================================
# Environment Variables
# ==========================================
# Ignore all .env files by default
.env
.env.*

# EXCEPT the example files (you want to commit these)
!.env.example
!.env.local.example

# ==========================================
# FRONTEND (Next.js / Node / React)
# ==========================================
# Dependencies
frontend/node_modules/
node_modules/

# Next.js build outputs
frontend/.next/
frontend/out/
frontend/build/
frontend/dist/

# Logs
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/pnpm-debug.log*
*.log

# Caching & Coverage
frontend/*.tsbuildinfo
frontend/coverage/

# ==========================================
# BACKEND (FastAPI / Python)
# ==========================================
# Virtual environments
backend/venv/
backend/env/
backend/.venv/

# Byte-compiled / Cached files
backend/__pycache__/
backend/*.py[cod]
backend/*$py.class
__pycache__/
*.pyc

# Pytest / Coverage
backend/.pytest_cache/
backend/.coverage
backend/htmlcov/

# Local database files
backend/*.sqlite3
backend/*.db
